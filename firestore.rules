rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == "ratangup386@gmail.com" || request.auth.token.email == "ashutoshgup396@gmail.com");
    }
    match /profile/{profileId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == "ratangup386@gmail.com" || request.auth.token.email == "ashutoshgup396@gmail.com");
    }
  }
}
